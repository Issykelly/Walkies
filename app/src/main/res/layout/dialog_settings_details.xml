<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/levelup_background"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:id="@+id/settingsDetailsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textSize="@dimen/header_text_size"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvUsernameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/username_label"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/body_text_size"
        android:layout_gravity="start"/>

    <TextView
        android:id="@+id/tvUsernameValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enter_username"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/tutorial_text_size"
        android:textStyle="bold"
        android:layout_gravity="start"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/current_city_label"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="@dimen/body_text_size"
        android:layout_gravity="start"/>

    <Spinner
        android:id="@+id/spinnerChangeCity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:minHeight="48dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchMute"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/mute_app"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/body_text_size"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSaveSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/save"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btnBackSettingsDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:textAllCaps="false" />

</LinearLayout>
