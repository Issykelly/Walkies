<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/choose_your_goal"
        android:textSize="@dimen/header_text_size"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/goal_message"
        android:textSize="@dimen/body_text_size"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/rgGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbLeaveHouse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="@string/goal_leave_house"
            android:textSize="@dimen/body_text_size"
            android:textColor="?android:attr/textColorPrimary" />

        <RadioButton
            android:id="@+id/rbFriends"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="@string/goal_friends"
            android:textSize="@dimen/body_text_size"
            android:textColor="?android:attr/textColorPrimary" />
    </RadioGroup>

    <Button
        android:id="@+id/btnGoalFinish"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/finish" />

</LinearLayout>
