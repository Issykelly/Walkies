<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="tamagotchi.Tamagotchi">

    <ImageView
        android:id="@+id/background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/background_description"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/plain" />

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_button_border"
        android:contentDescription="@string/back_desc"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_revert" />

    <ImageButton
        android:id="@+id/helpButton"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="92dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_button_border"
        android:contentDescription="@string/help_button"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_help" />

    <ImageButton
        android:id="@+id/confirmButton"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="168dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_button_border"
        android:contentDescription="@string/confirm"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/checkbox_on_background" />

    <ImageButton
        android:id="@+id/burgerMenu"
        style="@style/Widget.AppCompat.ImageButton"
        android:layout_width="90dp"
        android:layout_height="86dp"
        android:background="@drawable/rounded_button_border"
        android:contentDescription="@string/burger_desc"
        android:padding="12dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.95"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.019"
        app:srcCompat="@drawable/burger" />

    <LinearLayout
        android:id="@+id/mainMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/feed"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:adjustViewBounds="false"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/food_desc"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/food_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feed"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/bathe"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/bath_desc"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/bath_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bathe"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/walk"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/map_desc"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/foot_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/walk"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/dress"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/green_fill_with_border"
                android:contentDescription="@string/dress_desc"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/dress_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dress"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/foodMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/sock_10_10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/sock"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/socks_desc"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/sock" />

            <TextView
                android:id="@+id/sock_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sock"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/broccoli_20_25"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/broccoli"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/broc_desc"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/brocali" />

            <TextView
                android:id="@+id/broc_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/broccoli"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cheese_35_50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/cheese"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/cheese_desc"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/cheese" />

            <TextView
                android:id="@+id/cheese_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cheese"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/meat_50_100"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/meat"
                android:layout_width="78dp"
                android:layout_height="81dp"
                android:background="@drawable/button_background_dynamic"
                android:contentDescription="@string/meat_desc"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/food_icon" />

            <TextView
                android:id="@+id/meat_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meat"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/hatMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/noHat"
                    android:layout_width="78dp"
                    android:layout_height="81dp"
                    android:background="@drawable/rounded_button_border"
                    android:contentDescription="@string/no_hat"
                    android:scaleType="centerInside"
                    app:srcCompat="@android:drawable/ic_menu_close_clear_cancel" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/none"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/brownCowboy"
                    android:layout_width="78dp"
                    android:layout_height="81dp"
                    android:background="@drawable/rounded_button_border"
                    android:contentDescription="@string/a_brown_cowboy_hat"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/browncowboyhat" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brown"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/brownCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="100c"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/pinkCowboy"
                    android:layout_width="78dp"
                    android:layout_height="81dp"
                    android:background="@drawable/rounded_button_border"
                    android:contentDescription="@string/a_pink_cowboy_hat"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/pinkcowboyhat" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pink"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pinkCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="100c"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/greenParty"
                    android:layout_width="78dp"
                    android:layout_height="81dp"
                    android:background="@drawable/rounded_button_border"
                    android:contentDescription="@string/a_green_party_hat"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/partyhatgreen" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/green"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/greenCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="75c"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/pinkParty"
                    android:layout_width="78dp"
                    android:layout_height="81dp"
                    android:background="@drawable/rounded_button_border"
                    android:contentDescription="@string/a_pink_party_hat"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/partyhatpink" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pink"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pinkPartyCost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="75c"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <ImageView
        android:id="@+id/Dog"
        android:layout_width="364dp"
        android:layout_height="813dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="120dp"
        android:contentDescription="@string/dog_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/husky_idle"
        tools:ignore="VisualLintBounds" />

    <ImageView
        android:id="@+id/draggingFood"
        android:layout_width="138dp"
        android:layout_height="129dp"
        android:contentDescription="@string/food_minigame_desc"
        android:elevation="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/draggingSponge"
        android:layout_width="138dp"
        android:layout_height="129dp"
        android:contentDescription="@string/sponge_minigame_desc"
        android:elevation="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/sponge" />

    <ImageView
        android:id="@+id/suds"
        android:layout_width="307dp"
        android:layout_height="437dp"
        android:contentDescription="@string/suds_desc"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/burgerMenu"
        app:layout_constraintVertical_bias="0.83"
        app:srcCompat="@drawable/suds4" />

    <ImageView
        android:id="@+id/accessories"
        android:layout_width="326dp"
        android:layout_height="751dp"
        android:contentDescription="@string/accessory_desc"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.294"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.228"
        app:srcCompat="@drawable/browncowboyhat" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/statsGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="LevelImage,level,coinsImage,coins" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/coinGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="coinsImage,coins" />

    <androidx.constraintlayout.widget.Group
        android:id="@+id/levelGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="LevelImage,level" />

    <ImageButton
        android:id="@+id/LevelImage"
        android:layout_width="56dp"
        android:layout_height="66dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:background="#00FFFFFF"
        android:scaleType="centerCrop"
        android:src="@drawable/level"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/level"
        android:layout_width="41dp"
        android:layout_height="61dp"
        android:gravity="center"
        android:text="99"
        android:textColor="#000000"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/Dog"
        app:layout_constraintStart_toEndOf="@+id/LevelImage"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.271" />

    <ImageView
        android:id="@+id/coinsImage"
        android:layout_width="67dp"
        android:layout_height="68dp"
        android:layout_marginStart="172dp"
        android:src="@drawable/coin"
        app:layout_constraintBottom_toTopOf="@+id/Dog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.173" />

    <TextView
        android:id="@+id/coins"
        android:layout_width="63dp"
        android:layout_height="61dp"
        android:layout_marginStart="1dp"
        android:gravity="center"
        android:text="9999"
        android:textColor="#000000"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/Dog"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/coinsImage"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.254" />

    <TextView
        android:id="@+id/foodHint"
        android:layout_width="304dp"
        android:layout_height="98dp"
        android:text="@string/food_hint"
        android:textColor="#000000"
        android:textSize="24sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/Dog" />

    <TextView
        android:id="@+id/bathHint"
        android:layout_width="304dp"
        android:layout_height="98dp"
        android:text="@string/bath_hint"
        android:textColor="#000000"
        android:textSize="24sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/Dog" />

</androidx.constraintlayout.widget.ConstraintLayout>